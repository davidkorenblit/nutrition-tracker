# Environment Variables Template
# Copy this file to .env and fill in your real values.
# ⚠️  NEVER commit .env to git. Use Azure App Service > Configuration > Application Settings instead.

# ==== AUTHENTICATION & SECURITY ====
SECRET_KEY=<generate-with: python -c "import secrets; print(secrets.token_hex(32))">
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# ==== DATABASE ====
# Azure PostgreSQL Flexible Server connection string:
# postgresql://<user>:<password>@<host>.postgres.database.azure.com:5432/<dbname>?sslmode=require
# Supabase pooler (PgBouncer):
# postgresql://<user>:<password>@<host>.pooler.supabase.com:6543/<dbname>?sslmode=require
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<dbname>?sslmode=require

# ==== CLOUD STORAGE (Supabase) ====
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<your-supabase-anon-key>

# ==== EMAIL CONFIGURATION ====
SMTP_EMAIL=<your-smtp-email>
SMTP_PASSWORD=<your-smtp-app-password>

# ==== FRONTEND URL (CORS) ====
# Comma-separated or ' || '-separated list of allowed origins
FRONTEND_URL=https://<your-frontend>.azurestaticapps.net,http://localhost:3000

# ==== AI SERVICE (Google Gemini) ====
GEMINI_API_KEY=<your-gemini-api-key>

# ==== ENVIRONMENT ====
# Set to "production" on Azure — disables /docs and /redoc
ENVIRONMENT=development
